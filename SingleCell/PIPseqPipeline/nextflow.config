/*
 * Nextflow configuration file for Single-Cell QC Pipeline
 */

// Process configuration
process {
    // Default resources
    cpus = 2
    memory = 8.GB
    time = 4.h
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Container (optional - uncomment if using Docker/Singularity)
    // container = 'continuumio/miniconda3:latest'
    
    // Process-specific configurations
    withName: GENERATE_REPORT_DATA {
        cpus = 4
        memory = 16.GB
        time = 8.h
    }
    
    withName: GUIDE_ASSIGNMENT {
        cpus = 8
        memory = 32.GB
        time = 12.h
    }
}

// Execution profiles
profiles {
    // Local execution without containers
    local {
        process.executor = 'local'
        docker.enabled = false
        singularity.enabled = false
        
        // Ensure Python scripts in bin/ are executable
        process.beforeScript = 'export PATH="$PWD/bin:$PATH"'
    }
    
    // Local execution with cloud storage support (AWS S3 or GCP GCS)
    // Requires AWS CLI and/or Google Cloud SDK configured
    local_cloud {
        process.executor = 'local'
        docker.enabled = false
        singularity.enabled = false
        
        // AWS configuration for S3 access (optional)
        aws.region = 'us-east-1'  // Update with your AWS region
        // aws.profile = 'your-profile-name'  // Uncomment to use a specific AWS CLI profile
        
        // GCP configuration for GCS access (optional)
        google.location = 'us-central1'  // Update with your GCP location
        // google.project = 'your-gcp-project-id'  // Uncomment to set GCP project
        
        // Ensure Python scripts in bin/ are executable
        process.beforeScript = 'export PATH="$PWD/bin:$PATH"'
    }
    
    // Local execution with S3 support (requires AWS CLI configured)
    local_s3_bcl_admin {
        process.executor = 'local'
        docker.enabled = false
        singularity.enabled = false
        
        // AWS configuration for S3 access
        aws.region = 'us-east-1'  // Update with your AWS region
        aws.profile = 'bcl-admin'  // Uncomment to use a specific AWS CLI profile
        
        // Ensure Python scripts in bin/ are executable
        process.beforeScript = 'export PATH="$PWD/bin:$PATH"'

        params.outdir = 's3://your-bucket-name/results'  // Update with your S3 bucket
    }
    
    // AWS Batch execution with Docker containers
    awsbatch {
        process.executor = 'awsbatch'
        docker.enabled = true
        
        // AWS configuration
        aws.region = 'us-east-1'  // Update with your AWS region
        // aws.profile = 'your-profile-name'  // Uncomment to use a specific AWS CLI profile
        aws.batch.cliPath = '/usr/local/aws-cli/v2/current/bin/aws'
        
        // Work directory in S3
        workDir = 's3://your-bucket-name/work'  // Update with your S3 bucket
        
        // AWS Batch queue (update with your queue name)
        process.queue = 'your-batch-queue-name'
        
        // Container registry (update with your ECR repository)
        // Format: <account-id>.dkr.ecr.<region>.amazonaws.com/<repository>:<tag>
        params.container_qc = 'your-account.dkr.ecr.us-east-1.amazonaws.com/pipseq-qc:latest'
        
        // Set container for all processes
        process.container = params.container_qc
    }
    
    // Standard profile (alias for local)
    standard {
        process.executor = 'local'
        docker.enabled = false
    }
    
    // SLURM cluster execution
    cluster {
        process.executor = 'slurm'
        process.queue = 'short'
    }
    
    // GCP execution
    gcp {
        process.executor = 'google-lifesciences'
        docker.enabled = true
        workDir = 'gs://your-bucket/work'  // Update with your GCS bucket
        google.location = 'us-central1'
        google.project = 'your-gcp-project-id'  // Update with your GCP project
    }
    
    // Docker execution (local with Docker)
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.executor = 'local'
    }
    
    // Singularity execution
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.executor = 'local'
    }
}

// Resource limits
executor {
    name = 'local'
}

// Generate execution reports
timeline {
    enabled = true
    file = "${params.outdir}/${params.supersample_basename}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/${params.supersample_basename}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/${params.supersample_basename}/pipeline_info/trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/${params.supersample_basename}/pipeline_info/dag.svg"
    overwrite = true
}

// Manifest
manifest {
    name = 'single-cell-qc-pipeline'
    author = 'Michael Gatzen'
    description = 'Pipeline for processing single-cell QC metrics'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0.0'
}
