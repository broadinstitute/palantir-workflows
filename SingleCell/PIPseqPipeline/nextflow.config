/*
 * Nextflow configuration file for Single-Cell QC Pipeline
 */

// Global default params
params {
    // Input/output options
    num_input_cells = null
    data_dir = null                       // Directory containing all data files
    dragen_file_prefix = null             // Common prefix for all DRAGEN output files
    sample_id = null                      // Sample identifier
    output_basename = null                // Output basename for generated files
    run_guide_assignment = true
    outdir = "results"
    
    // Container options
    container_metrics = null              // Override with --container-metrics
    container_guide_assignment = null     // Override with --container-guide-assignment
    
    // Resource options
    max_cpus = 16
    max_memory = 64.GB
    max_time = 24.h
}

// Process configuration
process {
    // Default resources
    cpus = 2
    memory = 8.GB
    time = 4.h
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Container (optional - uncomment if using Docker/Singularity)
    // container = 'continuumio/miniconda3:latest'
    
    // Process-specific configurations
    withName: GENERATE_REPORT_DATA {
        cpus = 4
        memory = 16.GB
        time = 8.h
    }
    
    withName: EXTRACT_CRISPR_FEATURES {
        cpus = 4
        memory = 16.GB
        time = 4.h
    }
    
    withName: GUIDE_ASSIGNMENT {
        cpus = 8
        memory = 32.GB
        time = 12.h
    }
}

// Execution profiles
profiles {
    // Local execution without containers
    local {
        process.executor = 'local'
        docker.enabled = false
        singularity.enabled = false
        
        // Ensure Python scripts in bin/ are executable
        process.beforeScript = 'export PATH="$PWD/bin:$PATH"'
    }
    
    // AWS Batch execution with Docker containers
    awsbatch {
        process.executor = 'awsbatch'
        docker.enabled = true
        
        // AWS configuration
        aws.region = 'us-east-1'  // Update with your AWS region
        aws.batch.cliPath = '/usr/local/aws-cli/v2/current/bin/aws'
        
        // Work directory in S3
        workDir = 's3://your-bucket-name/work'  // Update with your S3 bucket
        
        // AWS Batch queue (update with your queue name)
        process.queue = 'your-batch-queue-name'
        
        // Container registry (update with your ECR repository)
        params.container_metrics = 'your-account.dkr.ecr.us-east-1.amazonaws.com/singlecell-qc-metrics:latest'
        params.container_crispr = 'your-account.dkr.ecr.us-east-1.amazonaws.com/singlecell-qc-crispr:latest'
        params.container_guide_assignment = 'your-account.dkr.ecr.us-east-1.amazonaws.com/singlecell-qc-guide-assignment:latest'
        
        // Set containers for processes
        process {
            withName: 'GENERATE_REPORT_DATA' {
                container = params.container_metrics
            }
            withName: 'EXTRACT_CRISPR_FEATURES' {
                container = params.container_crispr
            }
            withName: 'GUIDE_ASSIGNMENT' {
                container = params.container_guide_assignment
            }
        }
    }
    
    // Standard profile (alias for local)
    standard {
        process.executor = 'local'
        docker.enabled = false
    }
    
    // SLURM cluster execution
    cluster {
        process.executor = 'slurm'
        process.queue = 'short'
    }
    
    // GCP execution
    gcp {
        process.executor = 'google-lifesciences'
        docker.enabled = true
        workDir = 'gs://your-bucket/work'  // Update with your GCS bucket
        google.location = 'us-central1'
        google.project = 'your-gcp-project-id'  // Update with your GCP project
    }
    
    // Docker execution (local with Docker)
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.executor = 'local'
    }
    
    // Singularity execution
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.executor = 'local'
    }
}

// Resource limits
executor {
    name = 'local'
    cpus = params.max_cpus
    memory = params.max_memory
}

// Generate execution reports
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag.svg"
}

// Manifest
manifest {
    name = 'single-cell-qc-pipeline'
    author = 'Michael Gatzen'
    description = 'Pipeline for processing single-cell QC metrics'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0.0'
}
