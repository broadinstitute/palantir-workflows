/*
 * Custom configuration file for pipeline run
 * 
 * Copy this file to run.config and update the parameters below
 * Then run: nextflow run main.nf -c run.config -profile local_cloud
 */

params {
    // Required parameters
    num_input_cells = 10000
    samplesheet = 's3://your-bucket/path/to/samplesheet.csv'  // or gs:// or local path
    supersample_id = 'Supersample_A'
    supersample_basename = 'supersample_a'
    
    // Output location
    outdir = 's3://your-bucket/results'  // or gs:// or local path
    
    // Optional parameters
    run_guide_assignment = true
}

// Optional: Override profile settings here
// aws.region = 'us-west-2'
// aws.profile = 'your-profile'
